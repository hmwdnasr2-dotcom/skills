# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# Anthropic — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...

# ─── SERVER ───────────────────────────────────────────────────────────────────

PORT=4000
ARIA_BRAIN=claude                        # claude | deepseek | openai | gemini | ollama
ARIA_MODEL=claude-haiku-4-5-20251001     # model passed to the brain
ARIA_DEFAULT_USER=user-1                 # fallback userId for scheduled jobs

# ─── DEEPSEEK (alternative brain — cheaper than Claude) ───────────────────────
# 1. Get key: platform.deepseek.com → API Keys
# 2. Set ARIA_BRAIN=deepseek and ARIA_MODEL=deepseek-chat in .env
# 3. Or use /setdeepseek <key> in Telegram to switch live

DEEPSEEK_API_KEY=sk-...

# ─── TELEGRAM (optional) ──────────────────────────────────────────────────────
# 1. Create bot: message @BotFather → /newbot → copy token
# 2. Get your chat ID: message @userinfobot → copy the number
# 3. TELEGRAM_USER_ID must match the userId used in the web app

TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_CHAT_ID=987654321
TELEGRAM_USER_ID=user-1

# ─── EMAIL REPORTS (optional) ─────────────────────────────────────────────────
# Gmail: enable 2FA → myaccount.google.com/apppasswords → create App Password
# Reports are sent daily 20:00, weekly Sun, monthly 1st, quarterly, yearly

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
REPORT_EMAIL=you@gmail.com

# ─── OPTIONAL INTEGRATIONS ────────────────────────────────────────────────────

# OpenAI — only needed for long-term vector memory (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Perplexity — enables web search tool
PERPLEXITY_API_KEY=pplx-...

# Gmail connector (two-way email via OAuth2)
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...
GMAIL_REDIRECT_URI=http://localhost:4000/auth/gmail/callback
GMAIL_REFRESH_TOKEN=...

# n8n research webhook
N8N_RESEARCH_WEBHOOK_URL=https://your-n8n.example.com/webhook/research
